<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Flashcard_Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Flashcard_Mobile.Views"
    Title="Flashcard_Mobile">

    <TabBar>
        <Tab Title="Home" Icon="home_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}" />
        </Tab>

        <Tab Title="Favorites" Icon="heart_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:FavoritesPage}" />
        </Tab>

        <Tab Title="Search" Icon="search_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:SearchPage}" />
        </Tab>

        <Tab Title="Me" Icon="user_icon.svg">
            <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" />
        </Tab>
    </TabBar>
</Shell>