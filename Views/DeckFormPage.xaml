<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Flashcard_Mobile.Views.DeckFormPage"
    BackgroundColor="Black">

    <ScrollView>
        <VerticalStackLayout Padding="20,20,20,30" Spacing="14">
            <Label
                x:Name="TitleLabel"
                Text="Create Deck"
                FontSize="24"
                TextColor="White"
                Margin="0,0,0,10" />

            <Frame BackgroundColor="#F0F0F0" BorderColor="Transparent">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Name" FontSize="14" TextColor="Black" />
                    <Entry x:Name="NameEntry" Placeholder="Deck name" />

                    <Label Text="List" FontSize="14" TextColor="Black" Margin="0,8,0,0" />
                    <Entry x:Name="ListEntry" Placeholder="List name" />

                    <Label Text="Words count" FontSize="14" TextColor="Black" Margin="0,8,0,0" />
                    <Entry
                        x:Name="WordsCountEntry"
                        Placeholder="0"
                        Keyboard="Numeric" />
                </VerticalStackLayout>
            </Frame>

            <Button
                x:Name="DeleteButton"
                Text="Delete"
                IsVisible="False"
                BackgroundColor="{StaticResource Tertiary}"
                TextColor="White"
                Clicked="OnDeleteClicked" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button
                    Grid.Column="0"
                    Text="Cancel"
                    BackgroundColor="{StaticResource Gray500}"
                    TextColor="White"
                    Clicked="OnCancelClicked" />
                <Button
                    Grid.Column="1"
                    x:Name="SaveButton"
                    Text="Save"
                    BackgroundColor="{StaticResource Tertiary}"
                    TextColor="White"
                    Clicked="OnSaveClicked" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
