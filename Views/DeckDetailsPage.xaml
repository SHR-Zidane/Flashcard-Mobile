<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:Flashcard_Mobile.Models"
    x:Class="Flashcard_Mobile.Views.DeckDetailsPage"
    BackgroundColor="Black">

    <Grid RowDefinitions="Auto,Auto,*" Padding="20,20,20,0" RowSpacing="10">
        <Label
            x:Name="DeckTitleLabel"
            Grid.Row="0"
            Text="Deck"
            FontSize="22"
            FontAttributes="Bold"
            TextColor="White" />

        <Label
            x:Name="FlashcardsCountLabel"
            Grid.Row="1"
            TextColor="{StaticResource Gray300}" />

        <CollectionView
            Grid.Row="2"
            x:Name="FlashcardsView"
            SelectionMode="None"
            BackgroundColor="Transparent">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Flashcard">
                    <Frame Padding="12" Margin="0,0,0,10">
                        <VerticalStackLayout Spacing="6">
                            <Label
                                Text="{Binding Front}"
                                FontSize="16"
                                FontAttributes="Bold"
                                TextColor="Black" />
                            <Label
                                Text="{Binding Back}"
                                FontSize="14"
                                TextColor="{StaticResource Gray600}" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label
                    Text="No flashcards in this deck yet."
                    TextColor="{StaticResource Gray300}"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
